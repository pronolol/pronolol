{
  "openapi": "3.1.0",
  "info": {
    "title": "Pronolol API",
    "version": "1.0.0",
    "description": "API for managing esports match predictions and rankings"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    }
  ],
  "tags": [
    {
      "name": "Matches",
      "description": "Match management endpoints"
    },
    {
      "name": "Rankings",
      "description": "User ranking and leaderboard endpoints"
    },
    {
      "name": "Users",
      "description": "Authenticated user endpoints"
    }
  ],
  "components": {
    "schemas": {
      "Team": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          },
          "logoUrl": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "tag",
          "logoUrl"
        ],
        "description": "Team information"
      },
      "Match": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "matchDate": {
            "type": "string",
            "nullable": true,
            "format": "date-time"
          },
          "state": {
            "type": "string"
          },
          "bestOf": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "stage": {
            "type": "string",
            "nullable": true
          },
          "teamA": {
            "$ref": "#/components/schemas/Team"
          },
          "teamB": {
            "$ref": "#/components/schemas/Team"
          },
          "winner": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Team"
              },
              {
                "nullable": true
              }
            ]
          },
          "teamAScore": {
            "type": "integer",
            "nullable": true
          },
          "teamBScore": {
            "type": "integer",
            "nullable": true
          },
          "tournament": {
            "$ref": "#/components/schemas/Tournament"
          },
          "myPrediction": {
            "allOf": [
              { "$ref": "#/components/schemas/MyPrediction" },
              { "nullable": true }
            ]
          }
        },
        "required": [
          "id",
          "matchDate",
          "state",
          "bestOf",
          "stage",
          "teamA",
          "teamB",
          "winner",
          "teamAScore",
          "teamBScore",
          "tournament",
          "myPrediction"
        ],
        "description": "Match details with teams and tournament information"
      },
      "Tournament": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "league": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "imageUrl": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name",
              "imageUrl"
            ],
            "description": "League information"
          }
        },
        "required": [
          "id",
          "name",
          "league"
        ],
        "description": "Tournament information"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "details": {
            "nullable": true
          }
        },
        "required": [
          "error"
        ],
        "description": "Error response"
      },
      "MyPrediction": {
        "type": "object",
        "properties": {
          "matchId": {
            "type": "string"
          },
          "teamId": {
            "type": "string"
          },
          "predictedTeamAScore": {
            "type": "integer"
          },
          "predictedTeamBScore": {
            "type": "integer"
          },
          "isCorrect": {
            "type": "boolean",
            "nullable": true
          },
          "isExact": {
            "type": "boolean",
            "nullable": true
          },
          "points": {
            "type": "number",
            "nullable": true
          },
          "team": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "tag": {
                "type": "string"
              },
              "logoUrl": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "tag",
              "logoUrl"
            ]
          }
        },
        "required": [
          "matchId",
          "teamId",
          "predictedTeamAScore",
          "predictedTeamBScore",
          "isCorrect",
          "isExact",
          "points",
          "team"
        ]
      },
      "RankingResponse": {
        "type": "object",
        "properties": {
          "rankings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RankingEntry"
            }
          },
          "filters": {
            "type": "object",
            "properties": {
              "leagueId": {
                "type": "string",
                "nullable": true
              },
              "tournamentId": {
                "type": "string",
                "nullable": true
              }
            },
            "required": [
              "leagueId",
              "tournamentId"
            ]
          }
        },
        "required": [
          "rankings",
          "filters"
        ],
        "description": "Ranking response with user statistics"
      },
      "RankingEntry": {
        "type": "object",
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "userId": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "image": {
            "type": "string",
            "nullable": true
          },
          "totalPoints": {
            "type": "integer"
          },
          "totalPredictions": {
            "type": "integer"
          },
          "correctPredictions": {
            "type": "integer"
          },
          "exactPredictions": {
            "type": "integer"
          },
          "correctnessPercentage": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        },
        "required": [
          "rank",
          "userId",
          "displayName",
          "username",
          "image",
          "totalPoints",
          "totalPredictions",
          "correctPredictions",
          "exactPredictions",
          "correctnessPercentage"
        ],
        "description": "User ranking entry with statistics"
      }
    },
    "parameters": {}
  },
  "paths": {
    "/": {
      "get": {
        "description": "API Root",
        "summary": "Welcome endpoint",
        "responses": {
          "200": {
            "description": "Welcome message",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/matches": {
      "get": {
        "description": "Retrieve a list of matches with optional filtering by tournament, state, and pagination",
        "summary": "Get all matches",
        "tags": [
          "Matches"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "Filter matches by tournament ID",
              "example": "abc123"
            },
            "required": false,
            "description": "Filter matches by tournament ID",
            "name": "tournamentId",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "upcoming",
                "completed",
                "inProgress"
              ],
              "description": "Filter matches by state",
              "example": "upcoming"
            },
            "required": false,
            "description": "Filter matches by state",
            "name": "state",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "ISO date string to use as cursor for pagination. If not provided, current time is used.",
              "example": "2026-01-30T12:00:00.000Z"
            },
            "required": false,
            "description": "ISO date string to use as cursor for pagination. If not provided, current time is used.",
            "name": "cursor",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "before",
                "after",
                "around"
              ],
              "description": "Direction to fetch matches relative to cursor. 'around' returns matches both before and after.",
              "example": "around"
            },
            "required": false,
            "description": "Direction to fetch matches relative to cursor. 'around' returns matches both before and after.",
            "name": "direction",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Maximum number of results to return",
              "example": "20"
            },
            "required": false,
            "description": "Maximum number of results to return",
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "Number of results to skip for pagination",
              "example": "0"
            },
            "required": false,
            "description": "Number of results to skip for pagination",
            "name": "offset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List of matches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Match"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/matches/{id}": {
      "get": {
        "description": "Retrieve detailed information about a specific match including predictions",
        "summary": "Get match by ID",
        "tags": [
          "Matches"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "Match ID",
              "example": "match123"
            },
            "required": true,
            "description": "Match ID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Match details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Match"
                }
              }
            }
          },
          "404": {
            "description": "Match not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ranking": {
      "get": {
        "description": "Retrieve user rankings based on prediction performance. Can be filtered by league or tournament. Rankings are sorted by total points (descending), then by correctness percentage.",
        "summary": "Get user rankings",
        "tags": [
          "Rankings"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "leagueId",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "tournamentId",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "User rankings with statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RankingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/users/me/predictions": {
      "get": {
        "description": "Retrieve all predictions made by the authenticated user",
        "summary": "Get my predictions",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "List of the current user's predictions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "matchId": {
                        "type": "string"
                      },
                      "teamId": {
                        "type": "string"
                      },
                      "predictedTeamAScore": {
                        "type": "integer"
                      },
                      "predictedTeamBScore": {
                        "type": "integer"
                      },
                      "isCorrect": {
                        "type": "boolean",
                        "nullable": true
                      },
                      "isExact": {
                        "type": "boolean",
                        "nullable": true
                      },
                      "points": {
                        "type": "number",
                        "nullable": true
                      },
                      "team": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "tag": {
                            "type": "string"
                          },
                          "logoUrl": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "tag",
                          "logoUrl"
                        ]
                      }
                    },
                    "required": [
                      "matchId",
                      "teamId",
                      "predictedTeamAScore",
                      "predictedTeamBScore",
                      "isCorrect",
                      "isExact",
                      "points",
                      "team"
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}