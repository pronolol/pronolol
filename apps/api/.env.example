# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/pronolol

# Better Auth Configuration
# For local development, use your computer's local network IP
# To find your IP on macOS: ifconfig | grep "inet " | grep -v 127.0.0.1
# For production: use your full domain URL (e.g., https://api.yourdomain.com)
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-key-here-generate-a-long-random-string

# Discord OAuth (optional - for Discord login)
# Get these from: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=pronolol://auth/callback

# Environment
NODE_ENV=development
