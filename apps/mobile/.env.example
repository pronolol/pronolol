# API Configuration
# For local development on physical device or emulator, use your computer's local network IP
# To find your IP on macOS: ifconfig | grep "inet " | grep -v 127.0.0.1
# To find your IP on Windows: ipconfig
# For production: use your domain name

# Example for local development: EXPO_PUBLIC_API_URL=http://192.168.1.116:3000
# Example for production: EXPO_PUBLIC_API_URL=https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:3000
