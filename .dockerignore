# ===============================
# Docker Ignore
# ===============================

# Dependencies
node_modules
**/node_modules

# Build outputs
dist
**/dist
.next
**/.next

# Version control
.git
.gitignore

# Environment files (use docker-compose environment instead)
.env
.env.*
!.env.example

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Test files
coverage
**/*.test.ts
**/*.spec.ts
__tests__

# Documentation
*.md
!README.md
docs

# Mobile app (not needed in backend containers)
apps/mobile

# Docker files (avoid recursive copying)
docker-compose*.yml
compose*.yml
Dockerfile*

# Misc
.prettierrc
.prettierignore
eslint.config.js
