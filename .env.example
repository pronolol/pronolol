# ===============================
# Pronolol Environment Variables
# ===============================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ===============================
# Database Configuration
# ===============================
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=pronolol

# Database URL (auto-constructed in docker-compose, set manually for local dev)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/pronolol

PGADMIN_DEFAULT_EMAIL=admin@email.com
PGADMIN_DEFAULT_PASSWORD=admin

# ===============================
# API Configuration
# ===============================
# Port the API listens on
API_PORT=3000

# Host to bind to (0.0.0.0 for Docker, localhost for local dev)
API_HOST=0.0.0.0

# ===============================
# Authentication (Better Auth)
# ===============================
# Base URL for authentication callbacks
# Development: http://localhost:3000 or http://YOUR_LOCAL_IP:3000
# Production: https://api.yourdomain.com
BETTER_AUTH_URL=http://localhost:3000

# Secret key for signing tokens (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-key-change-in-production

# ===============================
# OAuth Providers (Optional)
# ===============================
# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ===============================
# Mobile App Configuration
# ===============================
# API URL for mobile app
# Development: http://YOUR_LOCAL_IP:3000 (use your machine's local network IP)
# Production: https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:3000

# ===============================
# Scraper Configuration
# ===============================
# Run mode: "once" for single run, "schedule" for cron-like behavior
SCRAPER_MODE=once

# Uptime Kuma push URL for heartbeat monitoring (optional)
# Get this from your Push monitor in Uptime Kuma
UPTIME_KUMA_PUSH_URL=

# ===============================
# Docker Compose Profiles
# ===============================
# Use: docker compose --profile development up
# Or:  docker compose --profile production up
#
# Profiles:
#   - development: Hot reload, exposed debug ports
#   - production: Optimized builds, health checks
